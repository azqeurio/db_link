    <string name="remote_usb_tether_guide_title">USB tether beta</string>
    <string name="remote_usb_tether_guide_step_1">If your camera body is OM-1 or later, choose OM in Settings. If it is before E-M1 Mark III, choose Olympus.</string>
    <string name="remote_usb_tether_guide_step_2">Set the camera to RAW / Control mode, then connect the camera and your device with USB and turn on the camera.</string>
